<Window x:Class="MeetingGoogle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeetingGoogle"
        xmlns:models="clr-namespace:MeetingGoogle.Models"
        mc:Ignorable="d"
        Title="Meeting Google"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip"
        Width="700"
        SizeToContent="Height"
        Left="100"
        Top="10"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        PreviewKeyDown="Window_PreviewKeyDown">

        <Border CornerRadius="10"
                Background="{StaticResource BarBg}"
                BorderBrush="#33FFFFFF"
                BorderThickness="1">
                <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                </Border.Effect>
                <Grid>
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Subtitle bar -->
                                <RowDefinition Height="Auto"/>
                                <!-- Settings panel -->
                                <RowDefinition Height="Auto"/>
                                <!-- History drawer -->
                        </Grid.RowDefinitions>

                        <!-- ═══ ROW 0: SUBTITLE BAR ═══ -->
                        <Grid Grid.Row="0"
                              MinHeight="48">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Status dot -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Subtitle text -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Buttons -->
                                </Grid.ColumnDefinitions>

                                <!-- Status indicator -->
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="12,0,8,0"
                                            VerticalAlignment="Center">
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 x:Name="StatusDot">
                                                <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                                <Setter Property="Fill"
                                                                        Value="#FF555555"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsConnected}"
                                                                                     Value="True">
                                                                                <Setter Property="Fill"
                                                                                        Value="#FF00CC66"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsAnalyzing}"
                                                                                     Value="True">
                                                                                <Setter Property="Fill"
                                                                                        Value="#FFFFAA00"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Ellipse.Style>
                                        </Ellipse>
                                        <!-- Dot de status do intérprete (dourado, visível quando conectado) -->
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 Fill="{StaticResource AccentGold}"
                                                 Margin="4,0,0,0"
                                                 VerticalAlignment="Center"
                                                 ToolTip="{Binding SpeakStatusText}"
                                                 Visibility="{Binding IsSpeakConnected, Converter={StaticResource BoolToVis}}"/>
                                        <!-- Dot pulsante dourado: indica que o intérprete está falando -->
                                        <Ellipse x:Name="SpeakingDot"
                                                 Width="8"
                                                 Height="8"
                                                 Fill="{StaticResource AccentGold}"
                                                 Margin="4,0,0,0"
                                                 VerticalAlignment="Center"
                                                 ToolTip="Intérprete falando"
                                                 Visibility="{Binding IsSpeaking, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="10"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Segoe UI"/>
                                </StackPanel>

                                <!-- Subtitle text -->
                                <ScrollViewer x:Name="SubtitleScrollViewer"
                                              Grid.Column="1"
                                              MaxHeight="80"
                                              VerticalScrollBarVisibility="Hidden"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock x:Name="SubtitleBlock"
                                                   Text="{Binding SubtitleText}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="16"
                                                   FontFamily="Segoe UI"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Padding="4,10,4,0"
                                                   TextAlignment="Left"/>
                                    </StackPanel>
                                </ScrollViewer>

                                <!-- Action buttons -->
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            Margin="4,0,8,0"
                                            VerticalAlignment="Center">
                                        <!-- History toggle -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="▼"
                                                Click="ToggleHistory_Click"
                                                ToolTip="Histórico"
                                                FontSize="10"
                                                Padding="6,4"/>

                                        <!-- Mute -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="{Binding MuteIcon}"
                                                Click="ToggleMute_Click"
                                                ToolTip="Mute/Unmute"/>

                                        <!-- Speak (Intérprete Ativo PT→EN) -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="🗣️"
                                                Click="ToggleSpeak_Click"
                                                ToolTip="{Binding SpeakButtonTooltip}"
                                                Visibility="{Binding IsSpeakFeatureEnabled, Converter={StaticResource BoolToVis}}"
                                                FontSize="14"/>

                                        <!-- Connect/Disconnect -->
                                        <Button Style="{StaticResource BarButton}"
                                                Click="ToggleConnect_Click"
                                                ToolTip="{Binding ConnectButtonText}">
                                                <Button.Content>
                                                        <TextBlock FontSize="14">
                                                                <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                                <Setter Property="Text"
                                                                                        Value="⚡"/>
                                                                                <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsConnected}"
                                                                                                     Value="True">
                                                                                                <Setter Property="Text"
                                                                                                        Value="⏹"/>
                                                                                        </DataTrigger>
                                                                                </Style.Triggers>
                                                                        </Style>
                                                                </TextBlock.Style>
                                                        </TextBlock>
                                                </Button.Content>
                                        </Button>

                                        <!-- Settings -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="⚙"
                                                Click="ToggleSettings_Click"
                                                ToolTip="Configurações"/>

                                        <!-- Minimize -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="―"
                                                Click="Minimize_Click"
                                                ToolTip="Minimizar"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Padding="6,6,6,8"/>

                                        <!-- Close -->
                                        <Button Style="{StaticResource BarButton}"
                                                Content="✕"
                                                Click="Close_Click"
                                                ToolTip="Fechar"
                                                FontSize="12"/>
                                </StackPanel>
                        </Grid>

                        <!-- ═══ ROW 1: SETTINGS PANEL (Tabs) ═══ -->
                        <Border x:Name="SettingsPanel"
                                Grid.Row="1"
                                Background="{StaticResource BarBgSolid}"
                                Visibility="Visible"
                                MaxHeight="0"
                                ClipToBounds="True"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="0,1,0,0">
                                <TabControl Style="{StaticResource DarkTabControl}" SelectedIndex="{Binding SelectedSettingsTab}">

                                        <!-- ── TAB: ENTRADA ── -->
                                        <TabItem Header="Entrada"
                                                 Style="{StaticResource DarkTabItem}">
                                                <StackPanel Margin="14,12">
                                                        <!-- Modo -->
                                                        <TextBlock Text="Modo"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="12"
                                                                   FontFamily="Segoe UI"/>
                                                        <ComboBox SelectedValue="{Binding SelectedMode}"
                                                                  SelectedValuePath="Tag">
                                                                <ComboBoxItem Content="🎙️ Voz"
                                                                              Tag="{x:Static models:TranslationMode.Voice}"/>
                                                                <ComboBoxItem Content="📝 Transcrição"
                                                                              Tag="{x:Static models:TranslationMode.Transcription}"/>
                                                        </ComboBox>
                                                        <TextBlock Text="{Binding ModeDescription}"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="10"
                                                                   FontFamily="Segoe UI"
                                                                   FontStyle="Italic"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,0,0,14"/>

                                                        <!-- INPUT -->
                                                        <TextBlock Text="INPUT"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="12"
                                                                   FontFamily="Segoe UI"/>
                                                        <ComboBox ItemsSource="{Binding AllInputDevices}"
                                                                  SelectedItem="{Binding SelectedInputDevice}"
                                                                  DisplayMemberPath="Name"/>

                                                        <Button Style="{StaticResource BarButton}"
                                                                Content="🔄 Atualizar dispositivos"
                                                                Click="RefreshDevices_Click"
                                                                HorizontalAlignment="Left"
                                                                Foreground="{StaticResource AccentBlue}"
                                                                FontSize="11"/>

                                                        <!-- OUTPUT -->
                                                        <TextBlock Text="OUTPUT (Gemini)"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="12"
                                                                   FontFamily="Segoe UI"
                                                                   Margin="0,10,0,0"/>
                                                        <ComboBox ItemsSource="{Binding OutputDevices}"
                                                                  SelectedItem="{Binding SelectedOutputDevice}"
                                                                  DisplayMemberPath="Name"/>

                                                </StackPanel>
                                        </TabItem>

                                        <!-- ── TAB: SAÍDA ── -->
                                        <TabItem Header="Saída (Gemini API Voice)"
                                                 Style="{StaticResource DarkTabItem}">
                                                <StackPanel Margin="14,12">
                                                        <TextBlock Text="As configurações de voz e idioma dependem da API do Gemini e devem ser definidas no backend." 
                                                                   Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10"/>
                                                        <!-- Habilitar -->
                                                        <CheckBox IsChecked="{Binding IsSpeakFeatureEnabled}"
                                                                  Margin="0,0,0,10">
                                                                <TextBlock Text="Habilitar Interação por Voz"
                                                                           Foreground="{StaticResource TextPrimary}"
                                                                           FontSize="12"
                                                                           FontFamily="Segoe UI"
                                                                           FontWeight="SemiBold"/>
                                                        </CheckBox>
                                                </StackPanel>
                                        </TabItem>

                                  </TabControl>
                        </Border>

                        <!-- ═══ ROW 2: HISTORY / CHAT DRAWER ═══ -->
                        <Border x:Name="HistoryPanel"
                                Grid.Row="2"
                                Background="{StaticResource BarBgSolid}"
                                Visibility="Visible"
                                MaxHeight="0"
                                ClipToBounds="True"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="0,1,0,0">
                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/> <!-- Input Area -->
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Grid Grid.Row="0"
                                              Margin="14,8,14,4">
                                                <TextBlock Foreground="{StaticResource AccentBlue}"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           FontFamily="Segoe UI"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="HISTÓRICO ({0})">
                                                            <Binding Path="History.Count"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Button Style="{StaticResource BarButton}"
                                                            Content="🗑 Limpar"
                                                            Click="ClearHistory_Click"
                                                            Margin="0,0,8,0"/>
                                                    <Button Style="{StaticResource BarButton}"
                                                            Content="▲ Esconder"
                                                            Click="ToggleHistory_Click"/>
                                                </StackPanel>
                                        </Grid>

                                        <!-- Conversation list -->
                                        <ListBox Grid.Row="1"
                                                 ItemsSource="{Binding History}"
                                                 ItemTemplate="{StaticResource HistoryItemTemplate}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 x:Name="HistoryList"
                                                 VirtualizingPanel.ScrollUnit="Pixel">
                                                <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                                <Setter Property="HorizontalContentAlignment"
                                                                        Value="Stretch"/>
                                                                <Setter Property="Padding"
                                                                        Value="0"/>
                                                                <Setter Property="Margin"
                                                                        Value="0"/>
                                                                <Setter Property="Background"
                                                                        Value="Transparent"/>
                                                                <Setter Property="Template">
                                                                        <Setter.Value>
                                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                                        <ContentPresenter/>
                                                                                </ControlTemplate>
                                                                        </Setter.Value>
                                                                </Setter>
                                                        </Style>
                                                </ListBox.ItemContainerStyle>
                                        </ListBox>

                                        <!-- Empty state -->
                                        <TextBlock Grid.Row="1"
                                                   Text="Nenhuma conversa ainda..."
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,20"
                                                   FontFamily="Segoe UI"
                                                   FontStyle="Italic">
                                                <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility"
                                                                        Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding History.Count}"
                                                                                     Value="0">
                                                                                <Setter Property="Visibility"
                                                                                        Value="Visible"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </TextBlock.Style>
                                        </TextBlock>
                                </Grid>
                        </Border>
                </Grid>
        </Border>
</Window>
