<Window x:Class="MeetingTranslator.ScreenCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Capture" WindowStyle="None" AllowsTransparency="True" 
        Background="#01000000" Topmost="True" WindowState="Normal" 
        WindowStartupLocation="Manual"
        Cursor="Cross"
        ShowInTaskbar="False"
        MouseDown="Window_MouseDown" MouseMove="Window_MouseMove" MouseUp="Window_MouseUp" KeyDown="Window_KeyDown">
    <Canvas x:Name="CaptureCanvas" Background="Transparent">
        <Rectangle x:Name="SelectionRectangle" Stroke="Red" StrokeThickness="2" Fill="#20FF0000" Visibility="Hidden"/>
    </Canvas>
</Window>
